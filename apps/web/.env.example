# Copy to .env or .env.local and fill in.

# Google AdSense (optional; Standard 10 — see umbrella docs/PLATFORM_STANDARDS.md)
# Leave unset for no ads. Replace public/ads.txt placeholder publisher id before production.
# VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# VITE_ADSENSE_SLOT=xxxxxxxxxx
# VITE_ADSENSE_GLOBAL_OFF=true
# VITE_ADSENSE_APPROVAL_MODE=true
# Server-side Gemini key (kept on the backend only)
GEMINI_API_KEY=

# Supabase (must match Bookiji project for SSO on kinetix.bookiji.com)
# Either Vite or Next-style names work:
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY= # Use sb_publishable_* when legacy keys are disabled
# Or: NEXT_PUBLIC_SUPABASE_URL= and NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY= / NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional identity providers. Only enabled providers are shown on login.
# VITE_AUTH_GOOGLE_ENABLED=true
# VITE_AUTH_APPLE_ENABLED=false
# VITE_AUTH_MICROSOFT_ENABLED=false

# Shared DB guardrails (Infisical)
# local + preview should resolve to dev; production resolves to prod.
# SHARED_DB_TIER=dev
# SHARED_DB_ENV_STRICT=1

# Temporary: bypass login (dev/test only). Set to 1 to skip auth and use a mock profile.
# Production builds always ignore this (fail closed).
# VITE_SKIP_AUTH=1

# Beta: full in-app feature access (default on). Set to false post-beta for plan-based gating.
# VITE_KINETIX_BETA_FULL_ACCESS=true

# Web shell is desktop-first and web-native by default (no legacy shell toggle).

# Build / CI: `vite build` uses `vite.config.ts` only (no monorepo-only deps). `pnpm dev` uses
# `vite.config.dev.ts` (OAuth + local AI middleware; needs umbrella `packages/` links).
# Default `tsconfig.json` is app `src` only (no `src/test`, no `@api/*`, no `withingsOAuthServer.ts`) so accidental `tsc`
# and Vercel never pull `api/`. Production `tsc` uses `tsconfig.build.json` (relaxed unused). Optional: `tsconfig.tests.json`
# covers tests + `@api/*` for IDE / manual `tsc -p tsconfig.tests.json` in a full umbrella checkout.

# Optional: Help Center mailto fallback if POST /support/ticket/create is unavailable (same structured JSON body)
# VITE_SUPPORT_EMAIL=support@example.com

# Optional: included in legacy escalation payload copy when applicable (release or build label)
# VITE_APP_VERSION=1.0.0

# Optional: Kinetix RAG service base URL (run indexing, support KB query, ticket create). If unset, dev tries localhost:3001–3010.
# VITE_RAG_SERVICE_URL=http://localhost:3001

# Optional: Help Center support AI (`POST /api/ai-chat`). Defaults to same-origin `/api/ai-chat` (Vercel) or dev middleware.
# VITE_HELP_CENTER_AI_URL=https://kinetix.example.com/api/ai-chat

# Help Center operator queue and KB approval flow
# KINETIX_SUPPORT_OPERATOR_USER_IDS=00000000-0000-0000-0000-000000000000,11111111-1111-1111-1111-111111111111
# KINETIX_APP_BASE_URL=https://kinetix.bookiji.com
# KINETIX_RAG_BASE_URL=https://kinetix-rag.example.com
# KINETIX_SUPPORT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# KINETIX_SUPPORT_EMAIL_TO=support@example.com
# KINETIX_SUPPORT_EMAIL_FROM=Kinetix Support <support@example.com>
# RESEND_API_KEY=re_...

# Supabase CLI Personal Access Token (for `supabase ...` commands only)
# Format: sbp_...
SUPABASE_ACCESS_TOKEN=

# Admin scripts (server-only; never expose to client bundles)
# Preferred modern key format: sb_secret_...
SUPABASE_SECRET_KEY=
# Optional compatibility aliases:
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SERVICE_KEY=
# High risk: coordinate key rotation across all consumers of shared dev/prod projects.

# Strava (optional: import runs)
VITE_STRAVA_CLIENT_ID=
# For production: set VITE_STRAVA_REDIRECT_URI=https://kinetix.bookiji.com/settings so OAuth
# redirects to the deployed domain. If unset, uses current origin (works for localhost).
# VITE_STRAVA_REDIRECT_URI=https://kinetix.bookiji.com/settings
STRAVA_CLIENT_SECRET=

# Optional API CORS allowlist for serverless endpoints (comma-separated origins).
# If unset, API keeps backward-compatible wildcard CORS.
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://kinetix.bookiji.com

# Optional hardening toggle: require Authorization header on AI endpoints.
# Off by default for backward compatibility.
# KINETIX_API_REQUIRE_AUTH=1

# Withings (optional: use smart scale weight for KPS)
VITE_WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# Optional: run entitlement validation with an existing signed-in access token:
# pnpm exec tsx scripts/test-entitlements-e2e.ts
# E2E_EMAIL=
# E2E_ACCESS_TOKEN=

# Billing (Kinetix Stripe subscription -> Bookiji webhook -> entitlements)
# All of these must be set for checkout route to work; keep same Stripe account as Bookiji.
# BILLING_ENABLED=true
# STRIPE_SECRET_KEY=sk_test_xxx
# KINETIX_STRIPE_PRICE_ID=price_xxx

# Canonical AI contract
# AI_MODE=ollama
# AI_MODE=gateway
# AI_PROVIDER=ollama
# AI_PROVIDER=gateway
# VERCEL_AI_BASE_URL=
# VERCEL_VIRTUAL_KEY=
# OPENAI_MODEL=gpt-4o-mini

# LLM provider (legacy switch). If unset: VERCEL=1 -> gateway, else -> ollama.
# KINETIX_LLM_PROVIDER=ollama
# KINETIX_LLM_PROVIDER=gateway

# Local Ollama (when provider is ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# OpenAI-compatible gateway (when provider is gateway; e.g. Vercel AI Gateway)
# AI_GATEWAY_BASE_URL=
# AI_GATEWAY_API_KEY=
# AI_GATEWAY_MODEL=gpt-4o-mini
# Or use OPENAI_API_KEY for key; OPENAI_MODEL for model.

# Optional: one-way Bookiji Inc umbrella memory bridge (governance visibility; default off).
# Requires a local clone of the Bookiji-inc umbrella repo with dependencies installed.
# KINETIX_UMBRELLA_MEMORY_BRIDGE=1
# BOOKIJI_INC_ROOT=/absolute/path/to/Bookiji-inc
# Optional: stderr debug logs for bridge spawn/exit (does not affect chat success path)
# KINETIX_UMBRELLA_MEMORY_BRIDGE_DEBUG=1
