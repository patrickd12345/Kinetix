# Copy to .env or .env.local and fill in.
# Server-side Gemini key (kept on the backend only)
GEMINI_API_KEY=

# Supabase (must match Bookiji project for SSO on kinetix.bookiji.com)
# Use same values as Bookiji NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Strava (optional: import runs)
VITE_STRAVA_CLIENT_ID=
VITE_STRAVA_REDIRECT_URI=http://localhost:5173/settings
STRAVA_CLIENT_SECRET=

# Withings (optional: use smart scale weight for KPS)
VITE_WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
