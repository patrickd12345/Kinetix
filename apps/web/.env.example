# Copy to .env or .env.local and fill in.
# Server-side Gemini key (kept on the backend only)
GEMINI_API_KEY=

# Supabase (must match Bookiji project for SSO on kinetix.bookiji.com)
# Either Vite or Next-style names work:
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY= # Use sb_publishable_* when legacy keys are disabled
# Or: NEXT_PUBLIC_SUPABASE_URL= and NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY= / NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Temporary: bypass login (local dev only). Set to 1 to skip auth and use a mock profile.
# VITE_SKIP_AUTH=1

# Web shell is desktop-first and web-native by default (no legacy shell toggle).

# Supabase CLI Personal Access Token (for `supabase ...` commands only)
# Format: sbp_...
SUPABASE_ACCESS_TOKEN=

# Admin scripts (server-only; never expose to client bundles)
# Preferred modern key format: sb_secret_...
SUPABASE_SECRET_KEY=

# Strava (optional: import runs)
VITE_STRAVA_CLIENT_ID=
# For production: set VITE_STRAVA_REDIRECT_URI=https://kinetix.bookiji.com/settings so OAuth
# redirects to the deployed domain. If unset, uses current origin (works for localhost).
# VITE_STRAVA_REDIRECT_URI=https://kinetix.bookiji.com/settings
STRAVA_CLIENT_SECRET=

# Optional API CORS allowlist for serverless endpoints (comma-separated origins).
# If unset, API keeps backward-compatible wildcard CORS.
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://kinetix.bookiji.com

# Optional hardening toggle: require Authorization header on AI endpoints.
# Off by default for backward compatibility.
# KINETIX_API_REQUIRE_AUTH=1

# Withings (optional: use smart scale weight for KPS)
VITE_WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# Optional: run full auth+entitlements test with: pnpm exec tsx scripts/test-entitlements-e2e.ts
# E2E_EMAIL=
# E2E_PASSWORD=

# LLM provider (canonical switch). If unset: VERCEL=1 -> gateway, else -> ollama.
# KINETIX_LLM_PROVIDER=ollama
# KINETIX_LLM_PROVIDER=gateway

# Local Ollama (when provider is ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# OpenAI-compatible gateway (when provider is gateway; e.g. Vercel AI Gateway)
# AI_GATEWAY_BASE_URL=
# AI_GATEWAY_API_KEY=
# AI_GATEWAY_MODEL=gpt-4o-mini
# Or use OPENAI_API_KEY for key; OPENAI_MODEL for model.
