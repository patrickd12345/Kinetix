{
    "name": "@kinetix/web",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "prebuild": "tsx ../../scripts/check-master-access.ts",
        "dev": "vite --config vite.config.dev.ts",
        "build:bookiji-packages": "node ../../scripts/build-bookiji-packages.mjs",
        "build": "pnpm run build:bookiji-packages && pnpm --filter @kinetix/core build && tsc -p tsconfig.build.json && vite build && node ../../scripts/check-web-bundle-budget.mjs",
        "preview": "vite preview",
        "lint": "eslint src --ext .ts,.tsx",
        "type-check": "tsc -p tsconfig.build.json --noEmit",
        "garmin:import": "tsx scripts/import-garmin.ts",
        "withings:weights": "tsx scripts/download-withings-weights.ts",
        "test": "pnpm run build:bookiji-packages && pnpm --filter @kinetix/core build && vitest run",
        "test:coverage": "pnpm run build:bookiji-packages && pnpm --filter @kinetix/core build && vitest run --coverage",
        "test:vitest:serial": "vitest run --pool forks --poolOptions.forks.minForks=1 --poolOptions.forks.maxForks=1",
        "test:e2e": "pnpm exec playwright test",
        "test:e2e:operator": "pnpm exec playwright test e2e/operator-support-queue-smoke.spec.ts",
        "test:e2e:headed": "pnpm exec playwright test --headed",
        "support-corpus:ingest": "node ./support-corpus/ingest-corpus.mjs"
    },
    "dependencies": {
        "@bookiji-inc/ai-runtime": "workspace:*",
        "@bookiji-inc/error-contract": "workspace:*",
        "@bookiji-inc/observability": "workspace:*",
        "@bookiji-inc/persistent-memory-runtime": "workspace:*",
        "@kinetix/core": "workspace:*",
        "@supabase/ssr": "^0.5.2",
        "@supabase/supabase-js": "^2.57.4",
        "@types/react-window": "^2.0.0",
        "dexie": "^3.2.4",
        "fit-file-parser": "^2.3.3",
        "jszip": "^3.10.1",
        "lucide-react": "^0.344.0",
        "openai": "^4.47.0",
        "react": "^18.2.0",
        "react-calendar": "^6.0.0",
        "react-dom": "^18.2.0",
        "react-markdown": "^10.1.0",
        "react-router-dom": "^6.21.1",
        "react-window": "^2.2.5",
        "recharts": "^3.7.0",
        "remark-gfm": "^4.0.1",
        "zustand": "^4.4.7"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.1",
        "@playwright/test": "^1.58.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^18.2.64",
        "@types/react-dom": "^18.2.21",
        "@typescript-eslint/eslint-plugin": "^6.15.0",
        "@typescript-eslint/parser": "^6.15.0",
        "@vercel/node": "^3.0.7",
        "@vitejs/plugin-react": "^4.2.1",
        "@vitest/coverage-v8": "^2.1.9",
        "adm-zip": "^0.5.10",
        "autoprefixer": "^10.4.18",
        "axe-core": "^4.11.2",
        "eslint": "^8.56.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.5",
        "jsdom": "^24.1.3",
        "postcss": "^8.4.35",
        "tailwindcss": "^3.4.1",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3",
        "vite": "^5.1.4",
        "vitest": "^2.1.9"
    }
}
