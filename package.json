{
  "name": "kinetix",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered Running Coach with KPS (Kinetix Performance Score)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @kinetix/web dev",
    "build": "pnpm --filter @kinetix/core build && pnpm --filter @kinetix/web build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
