{
  "name": "kinetix",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered Running Coach with Kinetix Performance Score (KPS)",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev": "concurrently -n rag,web -c cyan,yellow \"pnpm --filter @kinetix/rag start\" \"pnpm --filter @kinetix/web dev\"",
    "dev:infisical": "node scripts/dev-with-infisical.mjs",
    "verify:infisical": "node scripts/verify-infisical.mjs",
    "dev:web": "pnpm --filter @kinetix/web dev",
    "dev:rag": "pnpm --filter @kinetix/rag start",
    "build": "pnpm --filter @kinetix/core build && pnpm --filter @kinetix/web build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @kinetix/web test:e2e",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean",
    "check:no-local-ai-core": "node scripts/check-no-local-ai-core.mjs",
    "smoke:persistent-memory": "tsx api/smoke-persistent-memory.ts"
  },
  "dependencies": {
    "@bookiji-inc/error-contract": "link:../../packages/error-contract",
    "@bookiji-inc/ai-runtime": "link:../../packages/ai-runtime",
    "@bookiji-inc/observability": "link:../../packages/observability",
    "@bookiji-inc/persistent-memory-runtime": "link:../../packages/persistent-memory-runtime",
    "@bookiji-inc/stripe-runtime": "link:../../packages/stripe-runtime",
    "@bookiji-inc/platform-auth": "link:../../packages/platform-auth",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.57.4",
    "@vercel/node": "^3.0.0",
    "stripe": "^20.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": "22.x",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
