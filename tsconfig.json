{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@bookiji-inc/error-contract": [
        "monorepo-packages/error-contract/src",
        "../../packages/error-contract/src",
        ".bookiji-packages/error-contract/src"
      ],
      "@bookiji-inc/ai-core": [
        "../../packages/ai-core/src",
        "monorepo-packages/ai-core/src",
        ".bookiji-packages/ai-core/src"
      ],
      "@bookiji-inc/ai-runtime": [
        "../../packages/ai-runtime/src",
        "monorepo-packages/ai-runtime/src",
        ".bookiji-packages/ai-runtime/src"
      ],
      "@bookiji-inc/observability": [
        "monorepo-packages/observability/src",
        "../../packages/observability/src",
        ".bookiji-packages/observability/src"
      ],
      "@bookiji-inc/persistent-memory-runtime": [
        "monorepo-packages/persistent-memory-runtime/src",
        "../../packages/persistent-memory-runtime/src",
        ".bookiji-packages/persistent-memory-runtime/src"
      ],
      "@bookiji-inc/stripe-runtime": [
        "monorepo-packages/stripe-runtime/src",
        "../../packages/stripe-runtime/src",
        ".bookiji-packages/stripe-runtime/src"
      ],
      "@bookiji-inc/platform-auth": [
        "monorepo-packages/platform-auth/src",
        "../../packages/platform-auth/src",
        ".bookiji-packages/platform-auth/src"
      ]
    }
  },
  "include": ["packages/core/src", "api/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}