{
  "version": 2,
  "name": "kinetix",
  "buildCommand": "pnpm install && pnpm --filter @kinetix/core build && pnpm --filter @kinetix/web build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npx pnpm@8 install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/strava/(.*)",
      "destination": "/api/strava-proxy?path=$1"
    },
    {
      "source": "/api/strava-oauth",
      "destination": "/api/strava-oauth"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
