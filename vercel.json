{
  "version": 2,
  "buildCommand": "corepack enable && corepack prepare pnpm@10.30.3 --activate && pnpm --filter @kinetix/core build && pnpm --filter @kinetix/web build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "bash scripts/vercel-install.sh",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "api/package.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/withings-oauth",
      "destination": "/api/withings"
    },
    {
      "source": "/api/withings-refresh",
      "destination": "/api/withings"
    },
    {
      "source": "/api/strava/(.*)",
      "destination": "/api/strava-proxy?path=$1"
    },
    {
      "source": "/api/strava-oauth",
      "destination": "/api/strava-oauth"
    },
    {
      "source": "/api/strava-refresh",
      "destination": "/api/strava-refresh"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
